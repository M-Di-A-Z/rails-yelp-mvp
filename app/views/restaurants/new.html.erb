<h1>Create new restaurant</h1>
<div>

<%= simple_form_for @restaurant do|f| %>
  <%= f.input :name %>
  <%= f.input :address %>
  <%= f.input :phone_number %>
  <%= f.input :category, collection: ["chinese", "italian", "japanese", "french", "belgian"] %>
  <%= f.submit %>
<% end %>


</div>

<div><%= render "restaurants/index" , restaurant:@restaurant %></div>
